# Docker Images (set by CI/CD or manually)
BACKEND_IMAGE=task-tracker-backend:latest
FRONTEND_IMAGE=task-tracker-frontend:latest

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tasktracker

# JWT Configuration
JWT_SECRET=YourProductionSecretKeyThatIsAtLeast32CharactersLong!
JWT_ISSUER=TaskTracker
JWT_AUDIENCE=TaskTrackerApp
JWT_EXPIRATION=480